# =============================================================================
# AppControl v4 — Environment Variables
# =============================================================================
# Copy this file to .env and customize for your environment.

# ---- Required ----

# PostgreSQL connection string
DATABASE_URL=postgresql://appcontrol:appcontrol@localhost:5432/appcontrol

# JWT signing secret (>= 32 chars, random). Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-random-secret

# ---- Environment ----

# "production" | "staging" | "development" (default: development)
APP_ENV=development

# ---- Server ----

# Backend API port (default: 3000)
PORT=3000

# JWT issuer claim (default: appcontrol)
JWT_ISSUER=appcontrol

# ---- CORS ----

# Comma-separated allowed origins. Empty = permissive in dev, restrictive in prod.
# Example: CORS_ORIGINS=https://appcontrol.example.com,https://admin.example.com
CORS_ORIGINS=

# ---- Logging ----

# Log format: "text" (default) or "json" (structured, for production/log aggregation)
LOG_FORMAT=text

# Log level filter (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=appcontrol_backend=debug,tower_http=debug

# ---- OIDC (optional) ----

# OIDC discovery URL (enables OIDC authentication if set)
# OIDC_DISCOVERY_URL=https://auth.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=appcontrol
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://appcontrol.example.com/api/v1/auth/oidc/callback

# ---- SAML 2.0 (optional) ----

# SAML IdP SSO URL (enables SAML authentication if set)
# SAML_IDP_SSO_URL=https://idp.example.com/sso
# SAML_SP_ENTITY_ID=appcontrol
# SAML_ACS_URL=https://appcontrol.example.com/api/v1/auth/saml/acs

# ---- Rate Limiting ----

# Auth endpoints: max requests per IP per minute (default: 10)
RATE_LIMIT_AUTH=10

# Operation endpoints: max requests per user per minute (default: 5)
RATE_LIMIT_OPERATIONS=5

# Read endpoints: max requests per user per minute (default: 200)
RATE_LIMIT_READS=200

# ---- AI layer (sovereign inference router) ----
#
# Inference mode: "hybrid" (default — local for sensitive data, frontier for the
# rest, after redaction), or "local" (sovereign only, nothing ever leaves).
AI_INFERENCE_MODE=hybrid

# On-prem / sovereign model (vLLM, Ollama, TGI — any OpenAI-compatible endpoint).
# If unset, a deterministic mock is used so the demo still runs with zero infra.
# AI_LOCAL_BASE_URL=http://vllm:8000/v1
# AI_LOCAL_MODEL=qwen2.5:14b
# AI_LOCAL_API_KEY=

# Hosted frontier model (Azure OpenAI / OpenAI). Only redacted, non-sensitive
# context is ever routed here. If unset, the router is local-only.
# AI_FRONTIER_BASE_URL=https://my-azure-openai.openai.azure.com/openai/deployments/gpt-4o
# AI_FRONTIER_MODEL=gpt-4o
# AI_FRONTIER_API_KEY=

# Redact secrets/IPs/hostnames before anything reaches a frontier model.
AI_REDACTION_ENABLED=true

# Global kill-switch: when true, all AI autonomy is disabled (advisory only).
AI_KILL_SWITCH=false

# Default autonomy level: "advisory" | "approval" | "policy" (see AI_ACTION_PLAN.md).
AI_AUTONOMY_DEFAULT=approval
