{
  "name": "Microservices E-Commerce",
  "description": "Modern microservices architecture with API gateway, service mesh, message broker, and multiple independent services. Shows complex DAG with shared infrastructure layer.",
  "tags": { "env": "production", "architecture": "microservices", "team": "engineering" },
  "components": [
    {
      "name": "PostgreSQL (Orders)",
      "component_type": "database",
      "host": "db-orders.prod.internal",
      "check_cmd": "pg_isready -h localhost -p 5432",
      "start_cmd": "systemctl start postgresql-16",
      "stop_cmd": "systemctl stop postgresql-16",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 120,
      "position": { "x": 100, "y": 500 }
    },
    {
      "name": "PostgreSQL (Users)",
      "component_type": "database",
      "host": "db-users.prod.internal",
      "check_cmd": "pg_isready -h localhost -p 5432",
      "start_cmd": "systemctl start postgresql-16",
      "stop_cmd": "systemctl stop postgresql-16",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 120,
      "position": { "x": 400, "y": 500 }
    },
    {
      "name": "MongoDB (Catalog)",
      "component_type": "database",
      "host": "db-catalog.prod.internal",
      "check_cmd": "mongosh --eval 'db.runCommand({ping:1})' --quiet",
      "start_cmd": "systemctl start mongod",
      "stop_cmd": "systemctl stop mongod",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 60,
      "position": { "x": 700, "y": 500 }
    },
    {
      "name": "RabbitMQ",
      "component_type": "middleware",
      "host": "mq-01.prod.internal",
      "check_cmd": "rabbitmq-diagnostics check_running",
      "start_cmd": "systemctl start rabbitmq-server",
      "stop_cmd": "systemctl stop rabbitmq-server",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 60,
      "integrity_check_cmd": "rabbitmq-diagnostics check_port_connectivity",
      "position": { "x": 400, "y": 400 }
    },
    {
      "name": "Redis (Sessions)",
      "component_type": "cache",
      "host": "redis-01.prod.internal",
      "check_cmd": "redis-cli ping",
      "start_cmd": "systemctl start redis",
      "stop_cmd": "systemctl stop redis",
      "check_interval_secs": 15,
      "start_timeout_secs": 15,
      "stop_timeout_secs": 15,
      "position": { "x": 250, "y": 400 }
    },
    {
      "name": "Order Service",
      "component_type": "microservice",
      "host": "svc-orders.prod.internal",
      "check_cmd": "curl -sf http://localhost:8081/health",
      "start_cmd": "docker compose -f /opt/services/orders/docker-compose.yml up -d",
      "stop_cmd": "docker compose -f /opt/services/orders/docker-compose.yml down",
      "check_interval_secs": 30,
      "start_timeout_secs": 90,
      "stop_timeout_secs": 60,
      "position": { "x": 100, "y": 300 }
    },
    {
      "name": "User Service",
      "component_type": "microservice",
      "host": "svc-users.prod.internal",
      "check_cmd": "curl -sf http://localhost:8082/health",
      "start_cmd": "docker compose -f /opt/services/users/docker-compose.yml up -d",
      "stop_cmd": "docker compose -f /opt/services/users/docker-compose.yml down",
      "check_interval_secs": 30,
      "start_timeout_secs": 90,
      "stop_timeout_secs": 60,
      "position": { "x": 350, "y": 300 }
    },
    {
      "name": "Catalog Service",
      "component_type": "microservice",
      "host": "svc-catalog.prod.internal",
      "check_cmd": "curl -sf http://localhost:8083/health",
      "start_cmd": "docker compose -f /opt/services/catalog/docker-compose.yml up -d",
      "stop_cmd": "docker compose -f /opt/services/catalog/docker-compose.yml down",
      "check_interval_secs": 30,
      "start_timeout_secs": 90,
      "stop_timeout_secs": 60,
      "position": { "x": 600, "y": 300 }
    },
    {
      "name": "Payment Service",
      "component_type": "microservice",
      "host": "svc-payments.prod.internal",
      "check_cmd": "curl -sf http://localhost:8084/health",
      "start_cmd": "docker compose -f /opt/services/payments/docker-compose.yml up -d",
      "stop_cmd": "docker compose -f /opt/services/payments/docker-compose.yml down",
      "check_interval_secs": 30,
      "start_timeout_secs": 90,
      "stop_timeout_secs": 60,
      "position": { "x": 250, "y": 200 }
    },
    {
      "name": "Notification Service",
      "component_type": "microservice",
      "host": "svc-notifications.prod.internal",
      "check_cmd": "curl -sf http://localhost:8085/health",
      "start_cmd": "docker compose -f /opt/services/notifications/docker-compose.yml up -d",
      "stop_cmd": "docker compose -f /opt/services/notifications/docker-compose.yml down",
      "check_interval_secs": 60,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 30,
      "position": { "x": 550, "y": 200 }
    },
    {
      "name": "API Gateway (Kong)",
      "component_type": "gateway",
      "host": "api-gw.prod.internal",
      "check_cmd": "curl -sf http://localhost:8001/status | grep -q 'database.*reachable'",
      "start_cmd": "systemctl start kong",
      "stop_cmd": "systemctl stop kong",
      "check_interval_secs": 15,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15,
      "position": { "x": 400, "y": 50 }
    },
    {
      "name": "Frontend (React SPA)",
      "component_type": "webserver",
      "host": "web-01.prod.internal",
      "check_cmd": "curl -sf http://localhost:3000/ > /dev/null",
      "start_cmd": "systemctl start nginx",
      "stop_cmd": "systemctl stop nginx",
      "check_interval_secs": 30,
      "start_timeout_secs": 10,
      "stop_timeout_secs": 10,
      "position": { "x": 400, "y": 150 }
    }
  ],
  "dependencies": [
    { "from": "Order Service", "to": "PostgreSQL (Orders)", "type": "strong" },
    { "from": "Order Service", "to": "RabbitMQ", "type": "strong" },
    { "from": "Order Service", "to": "Redis (Sessions)", "type": "weak" },
    { "from": "User Service", "to": "PostgreSQL (Users)", "type": "strong" },
    { "from": "User Service", "to": "Redis (Sessions)", "type": "strong" },
    { "from": "Catalog Service", "to": "MongoDB (Catalog)", "type": "strong" },
    { "from": "Payment Service", "to": "Order Service", "type": "strong" },
    { "from": "Payment Service", "to": "User Service", "type": "strong" },
    { "from": "Notification Service", "to": "RabbitMQ", "type": "strong" },
    { "from": "Notification Service", "to": "User Service", "type": "weak" },
    { "from": "Frontend (React SPA)", "to": "API Gateway (Kong)", "type": "strong" },
    { "from": "API Gateway (Kong)", "to": "Order Service", "type": "strong" },
    { "from": "API Gateway (Kong)", "to": "User Service", "type": "strong" },
    { "from": "API Gateway (Kong)", "to": "Catalog Service", "type": "strong" },
    { "from": "API Gateway (Kong)", "to": "Payment Service", "type": "strong" },
    { "from": "API Gateway (Kong)", "to": "Notification Service", "type": "weak" }
  ],
  "notes": {
    "start_order": "Databases + MQ + Cache (infra layer, parallel) → Microservices (service layer, parallel) → API Gateway → Frontend",
    "stop_order": "Frontend → API Gateway → Services → Infrastructure",
    "scaling": "Each microservice can scale independently. API Gateway handles routing.",
    "failure_isolation": "Catalog Service failure does not impact Order/Payment flow (weak dependency from Gateway)."
  }
}
