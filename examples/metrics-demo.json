{
  "name": "Metrics Demo",
  "description": "Demonstrates check commands that output operational metrics for monitoring and dashboards",
  "tags": {
    "env": "demo",
    "purpose": "metrics-testing"
  },
  "components": [
    {
      "name": "postgres-db",
      "display_name": "PostgreSQL Database",
      "description": "Database with connection count and replication lag metrics",
      "component_type": "database",
      "host": "localhost",
      "check_cmd": "test -f /tmp/metrics_demo_postgres.flag && echo '{\"connections\": 42, \"replication_lag_ms\": 150, \"cache_hit_ratio\": 0.98}'",
      "start_cmd": "touch /tmp/metrics_demo_postgres.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_postgres.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 30
    },
    {
      "name": "redis-cache",
      "display_name": "Redis Cache",
      "description": "Cache with memory usage and key count metrics (mixed output format)",
      "component_type": "cache",
      "host": "localhost",
      "check_cmd": "test -f /tmp/metrics_demo_redis.flag && echo 'Redis is healthy' && echo '{\"memory_mb\": 256, \"keys\": 15420, \"hit_rate\": 0.92, \"evictions\": 0}'",
      "start_cmd": "touch /tmp/metrics_demo_redis.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_redis.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15
    },
    {
      "name": "kafka-broker",
      "display_name": "Kafka Broker",
      "description": "Message broker with topic and consumer lag metrics (METRICS marker format)",
      "component_type": "middleware",
      "host": "localhost",
      "cluster_size": 3,
      "cluster_nodes": ["kafka-1.local", "kafka-2.local", "kafka-3.local"],
      "check_cmd": "test -f /tmp/metrics_demo_kafka.flag && echo 'Kafka broker running' && echo 'Checking partitions...' && echo '---METRICS---' && echo '{\"topics\": 12, \"partitions\": 48, \"consumer_lag\": 1250, \"messages_per_sec\": 5420}'",
      "start_cmd": "touch /tmp/metrics_demo_kafka.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_kafka.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 30
    },
    {
      "name": "api-gateway",
      "display_name": "API Gateway",
      "description": "Gateway with request rate and error metrics (pure JSON output)",
      "component_type": "gateway",
      "host": "localhost",
      "cluster_size": 2,
      "cluster_nodes": ["gateway-1.local", "gateway-2.local"],
      "check_cmd": "test -f /tmp/metrics_demo_gateway.flag && cat <<'EOF'\n{\"requests_per_min\": 12500, \"error_rate\": 0.002, \"p99_latency_ms\": 45, \"active_connections\": 320}\nEOF",
      "start_cmd": "touch /tmp/metrics_demo_gateway.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_gateway.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15
    },
    {
      "name": "backend-api",
      "display_name": "Backend API",
      "description": "Application server with business metrics",
      "component_type": "application",
      "host": "localhost",
      "check_cmd": "test -f /tmp/metrics_demo_backend.flag && echo '{\"active_users\": 145, \"orders_today\": 523, \"avg_response_ms\": 28, \"threads_active\": 12}'",
      "start_cmd": "touch /tmp/metrics_demo_backend.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_backend.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15
    },
    {
      "name": "worker-pool",
      "display_name": "Background Workers",
      "description": "Job processing workers with queue depth metrics",
      "component_type": "batch",
      "host": "localhost",
      "check_cmd": "test -f /tmp/metrics_demo_workers.flag && echo '{\"workers_active\": 8, \"queue_depth\": 42, \"jobs_completed_last_hour\": 1520, \"failed_jobs\": 3}'",
      "start_cmd": "touch /tmp/metrics_demo_workers.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_workers.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15
    },
    {
      "name": "frontend",
      "display_name": "Frontend App",
      "description": "Static assets served by nginx with request metrics",
      "component_type": "webfront",
      "host": "localhost",
      "check_cmd": "test -f /tmp/metrics_demo_frontend.flag && echo '{\"requests_per_sec\": 850, \"bandwidth_mbps\": 12.5, \"cache_hit_ratio\": 0.95}'",
      "start_cmd": "touch /tmp/metrics_demo_frontend.flag",
      "stop_cmd": "rm -f /tmp/metrics_demo_frontend.flag",
      "check_interval_secs": 10,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 15
    }
  ],
  "dependencies": [
    {"from": "redis-cache", "to": "postgres-db"},
    {"from": "kafka-broker", "to": "postgres-db"},
    {"from": "backend-api", "to": "redis-cache"},
    {"from": "backend-api", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "postgres-db"},
    {"from": "api-gateway", "to": "backend-api"},
    {"from": "frontend", "to": "api-gateway"}
  ]
}
