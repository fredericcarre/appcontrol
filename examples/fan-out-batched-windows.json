{
  "name": "Fan-out Batched Concurrency Demo (Windows)",
  "description": "v1.18.0 fan-out concurrency: the IIS tier has 8 members but they don't all start at once. With `cluster_concurrency_mode: batched` and `cluster_batch_size: 3`, the sequencer fires 3 starts in parallel, waits for the aggregate parent state to converge to RUNNING (or the start window to expire), then fires the next 3, then the last 2. Use this on real tiers to avoid stomping a downstream DB / auth / LB when 100+ members come up at once. Reuses the `marker-*.bat` helpers installed by demo-rebuild/scripts/windows/setup.bat.",
  "tags": { "env": "demo", "feature": "fan-out-batched", "os": "windows" },
  "components": [
    {
      "name": "SQL Server",
      "display_name": "SQL Server (downstream — feels the load)",
      "component_type": "database",
      "host": "agent-win-primary",
      "check_cmd": "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-check.bat primary sqlserver",
      "start_cmd": "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-start.bat primary sqlserver",
      "stop_cmd":  "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-stop.bat  primary sqlserver 2>nul & exit /b 0",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 60,
      "stop_timeout_seconds": 30,
      "position": { "x": 500, "y": 500 }
    },
    {
      "name": "IIS App Tier",
      "display_name": "IIS Pool (fan-out, 8 nodes, batched x3)",
      "component_type": "appserver",
      "host": "agent-win-primary",
      "cluster_mode": "fan_out",
      "cluster_health_policy": "threshold_pct",
      "cluster_min_healthy_pct": 75,
      "// concurrency_mode": "'batched' = chunked dispatch; the sequencer waits for the parent to be healthy after each batch before firing the next. Use 'parallel' (default) to fire all members at once like v1.17.x did. NULL or omitted = parallel.",
      "cluster_concurrency_mode": "batched",
      "// batch_size": "Members per batch when batched. NULL falls back to a built-in default of 10.",
      "cluster_batch_size": 3,
      "check_cmd": "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-check.bat primary iis-default",
      "start_cmd": "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-start.bat primary iis-default",
      "stop_cmd":  "%TEMP%\\appcontrol-demo-rebuild\\bin\\marker-stop.bat  primary iis-default 2>nul & exit /b 0",
      "check_interval_seconds": 10,
