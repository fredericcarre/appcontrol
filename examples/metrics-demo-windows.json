{
  "name": "Metrics Demo",
  "description": "Demonstrates check commands with operational metrics (Windows). Simple CMD commands.",
  "tags": {
    "env": "demo",
    "purpose": "metrics-showcase"
  },
  "components": [
    {
      "name": "postgres-db",
      "display_name": "PostgreSQL Database",
      "component_type": "database",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_postgres.flag",
      "start_cmd": "echo {\"connections\": 42, \"cache_hit_ratio\": 98, \"cache_hit_ratio_widget\": \"gauge\", \"database_size_mb\": 2048, \"version\": \"PostgreSQL 16.2\", \"version_widget\": \"text\"} > %TEMP%\\md_postgres.flag",
      "stop_cmd": "del %TEMP%\\md_postgres.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "redis-cache",
      "display_name": "Redis Cache",
      "component_type": "cache",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_redis.flag",
      "start_cmd": "echo {\"memory_percent\": 64, \"memory_percent_widget\": \"gauge\", \"keys\": 15420, \"hit_rate\": 92, \"hit_rate_widget\": \"gauge\", \"status\": \"ok\", \"status_widget\": \"status\"} > %TEMP%\\md_redis.flag",
      "stop_cmd": "del %TEMP%\\md_redis.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "kafka-broker",
      "display_name": "Kafka Broker",
      "component_type": "middleware",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_kafka.flag",
      "start_cmd": "echo {\"topics\": 12, \"partitions\": 48, \"consumer_lag\": 1250, \"broker_status\": \"ok\", \"broker_status_widget\": \"status\"} > %TEMP%\\md_kafka.flag",
      "stop_cmd": "del %TEMP%\\md_kafka.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "api-gateway",
      "display_name": "API Gateway",
      "component_type": "gateway",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_gateway.flag",
      "start_cmd": "echo {\"requests_per_min\": 12500, \"error_rate\": 0.2, \"error_rate_widget\": \"gauge\", \"p99_latency_ms\": 45, \"active_connections\": 320} > %TEMP%\\md_gateway.flag",
      "stop_cmd": "del %TEMP%\\md_gateway.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "backend-api",
      "display_name": "Backend API",
      "component_type": "appserver",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_backend.flag",
      "start_cmd": "echo {\"active_users\": 145, \"orders_today\": 523, \"avg_response_ms\": 28, \"heap_percent\": 65, \"heap_percent_widget\": \"gauge\"} > %TEMP%\\md_backend.flag",
      "stop_cmd": "del %TEMP%\\md_backend.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "worker-pool",
      "display_name": "Background Workers",
      "component_type": "batch",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_workers.flag",
      "start_cmd": "echo {\"workers_active\": 8, \"queue_depth\": 42, \"job_status\": \"ok\", \"job_status_widget\": \"status\"} > %TEMP%\\md_workers.flag",
      "stop_cmd": "del %TEMP%\\md_workers.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "frontend",
      "display_name": "Frontend App",
      "component_type": "webfront",
      "host": "localhost",
      "check_cmd": "type %TEMP%\\md_frontend.flag",
      "start_cmd": "echo {\"requests_per_sec\": 850, \"bandwidth_mbps\": 12.5, \"cache_hit_ratio\": 95, \"cache_hit_ratio_widget\": \"gauge\"} > %TEMP%\\md_frontend.flag",
      "stop_cmd": "del %TEMP%\\md_frontend.flag 2>nul",
      "check_interval_secs": 10
    }
  ],
  "dependencies": [
    {"from": "redis-cache", "to": "postgres-db"},
    {"from": "kafka-broker", "to": "postgres-db"},
    {"from": "backend-api", "to": "redis-cache"},
    {"from": "backend-api", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "postgres-db"},
    {"from": "api-gateway", "to": "backend-api"},
    {"from": "frontend", "to": "api-gateway"}
  ]
}
