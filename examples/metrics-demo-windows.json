{
  "name": "Metrics Demo",
  "description": "Demonstrates check commands with operational metrics (Windows version). Uses PowerShell for JSON output and CMD for start/stop.",
  "tags": {
    "env": "demo",
    "purpose": "metrics-showcase"
  },
  "components": [
    {
      "name": "postgres-db",
      "display_name": "PostgreSQL Database",
      "description": "Database with gauge and version text",
      "component_type": "database",
      "host": "localhost",
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_postgres.flag) { '{\\\"connections\\\": 42, \\\"replication_lag_ms\\\": 150, \\\"cache_hit_ratio\\\": 98, \\\"cache_hit_ratio_widget\\\": \\\"gauge\\\", \\\"database_size_mb\\\": 2048, \\\"version\\\": \\\"PostgreSQL 16.2\\\", \\\"version_widget\\\": \\\"text\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_postgres.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_postgres.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "redis-cache",
      "display_name": "Redis Cache",
      "description": "Cache with memory gauge and status indicator",
      "component_type": "cache",
      "host": "localhost",
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_redis.flag) { '{\\\"memory_percent\\\": 64, \\\"memory_percent_widget\\\": \\\"gauge\\\", \\\"keys\\\": 15420, \\\"hit_rate\\\": 92, \\\"hit_rate_widget\\\": \\\"gauge\\\", \\\"status\\\": \\\"ok\\\", \\\"status_widget\\\": \\\"status\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_redis.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_redis.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "kafka-broker",
      "display_name": "Kafka Broker",
      "description": "Message broker with sparkline for message rate",
      "component_type": "middleware",
      "host": "localhost",
      "cluster_size": 3,
      "cluster_nodes": ["kafka-1.local", "kafka-2.local", "kafka-3.local"],
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_kafka.flag) { '{\\\"topics\\\": 12, \\\"partitions\\\": 48, \\\"consumer_lag\\\": 1250, \\\"messages_per_sec\\\": [5420, 5380, 5510, 5440], \\\"messages_per_sec_widget\\\": \\\"sparkline\\\", \\\"broker_status\\\": \\\"ok\\\", \\\"broker_status_widget\\\": \\\"status\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_kafka.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_kafka.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "api-gateway",
      "display_name": "API Gateway",
      "description": "Gateway with request rate and bars",
      "component_type": "gateway",
      "host": "localhost",
      "cluster_size": 2,
      "cluster_nodes": ["gateway-1.local", "gateway-2.local"],
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_gateway.flag) { '{\\\"requests_per_min\\\": 12500, \\\"error_rate\\\": 0.2, \\\"error_rate_widget\\\": \\\"gauge\\\", \\\"p99_latency_ms\\\": 45, \\\"active_connections\\\": 320, \\\"backends\\\": {\\\"api\\\": 95, \\\"auth\\\": 100, \\\"static\\\": 100}, \\\"backends_widget\\\": \\\"bars\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_gateway.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_gateway.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "backend-api",
      "display_name": "Backend API",
      "description": "Application server with pie chart and gauge",
      "component_type": "appserver",
      "host": "localhost",
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_backend.flag) { '{\\\"active_users\\\": 145, \\\"orders_today\\\": 523, \\\"avg_response_ms\\\": 28, \\\"threads\\\": {\\\"active\\\": 12, \\\"idle\\\": 38, \\\"blocked\\\": 2}, \\\"threads_widget\\\": \\\"pie\\\", \\\"heap_percent\\\": 65, \\\"heap_percent_widget\\\": \\\"gauge\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_backend.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_backend.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "worker-pool",
      "display_name": "Background Workers",
      "description": "Job processing with sparkline and status",
      "component_type": "batch",
      "host": "localhost",
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_workers.flag) { '{\\\"workers_active\\\": 8, \\\"workers_active_widget\\\": \\\"number\\\", \\\"queue_depth\\\": 42, \\\"queue_depth_widget\\\": \\\"bar\\\", \\\"jobs_last_hour\\\": [150, 142, 168, 155], \\\"jobs_last_hour_widget\\\": \\\"sparkline\\\", \\\"job_status\\\": \\\"warning\\\", \\\"job_status_widget\\\": \\\"status\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_workers.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_workers.flag 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "frontend",
      "display_name": "Frontend App",
      "description": "Static assets with cache gauge",
      "component_type": "webfront",
      "host": "localhost",
      "check_cmd": "powershell -NoProfile -Command \"if (Test-Path $env:TEMP\\metrics_demo_frontend.flag) { '{\\\"requests_per_sec\\\": 850, \\\"bandwidth_mbps\\\": 12.5, \\\"cache_hit_ratio\\\": 95, \\\"cache_hit_ratio_widget\\\": \\\"gauge\\\"}'; exit 0 } else { exit 1 }\"",
      "start_cmd": "cmd /C echo.> %TEMP%\\metrics_demo_frontend.flag",
      "stop_cmd": "cmd /C del /f /q %TEMP%\\metrics_demo_frontend.flag 2>nul",
      "check_interval_secs": 10
    }
  ],
  "dependencies": [
    {"from": "redis-cache", "to": "postgres-db"},
    {"from": "kafka-broker", "to": "postgres-db"},
    {"from": "backend-api", "to": "redis-cache"},
    {"from": "backend-api", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "postgres-db"},
    {"from": "api-gateway", "to": "backend-api"},
    {"from": "frontend", "to": "api-gateway"}
  ]
}
