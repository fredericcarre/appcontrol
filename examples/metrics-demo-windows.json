{
  "name": "Metrics Demo",
  "description": "Demonstrates check commands with operational metrics (Windows). Run metrics-demo-setup.ps1 first, then copy metrics-demo-check.bat next to the agent exe.",
  "tags": {
    "env": "demo",
    "purpose": "metrics-showcase"
  },
  "components": [
    {
      "name": "postgres-db",
      "display_name": "PostgreSQL Database",
      "component_type": "database",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat postgres-db",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\postgres-db.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\postgres-db.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "redis-cache",
      "display_name": "Redis Cache",
      "component_type": "cache",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat redis-cache",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\redis-cache.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\redis-cache.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "kafka-broker",
      "display_name": "Kafka Broker",
      "component_type": "middleware",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat kafka-broker",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\kafka-broker.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\kafka-broker.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "api-gateway",
      "display_name": "API Gateway",
      "component_type": "gateway",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat api-gateway",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\api-gateway.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\api-gateway.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "backend-api",
      "display_name": "Backend API",
      "component_type": "appserver",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat backend-api",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\backend-api.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\backend-api.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "worker-pool",
      "display_name": "Background Workers",
      "component_type": "batch",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat worker-pool",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\worker-pool.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\worker-pool.running 2>nul",
      "check_interval_secs": 10
    },
    {
      "name": "frontend",
      "display_name": "Frontend App",
      "component_type": "webfront",
      "host": "localhost",
      "check_cmd": "metrics-demo-check.bat frontend",
      "start_cmd": "type nul > %TEMP%\\appcontrol_demo\\frontend.running",
      "stop_cmd": "del %TEMP%\\appcontrol_demo\\frontend.running 2>nul",
      "check_interval_secs": 10
    }
  ],
  "dependencies": [
    {"from": "redis-cache", "to": "postgres-db"},
    {"from": "kafka-broker", "to": "postgres-db"},
    {"from": "backend-api", "to": "redis-cache"},
    {"from": "backend-api", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "kafka-broker"},
    {"from": "worker-pool", "to": "postgres-db"},
    {"from": "api-gateway", "to": "backend-api"},
    {"from": "frontend", "to": "api-gateway"}
  ]
}
