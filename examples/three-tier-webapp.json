{
  "name": "E-Commerce Platform",
  "description": "Classic 3-tier web application: load balancer → app servers → database cluster. Demonstrates DAG sequencing with start order DB → App → LB and stop in reverse.",
  "tags": { "env": "production", "tier": "critical", "team": "platform" },
  "components": [
    {
      "name": "PostgreSQL Primary",
      "component_type": "database",
      "host": "db-primary.prod.internal",
      "check_cmd": "pg_isready -h localhost -p 5432 -U appuser",
      "start_cmd": "systemctl start postgresql-16",
      "stop_cmd": "systemctl stop postgresql-16",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 120,
      "integrity_check_cmd": "psql -U appuser -c 'SELECT count(*) FROM pg_stat_activity WHERE state = $$active$$'",
      "infra_check_cmd": "df -h /var/lib/pgsql | awk 'NR==2 {if ($5+0 > 90) exit 1}'",
      "rebuild_cmd": "pg_basebackup -h db-standby -D /var/lib/pgsql/16/data -R",
      "position": { "x": 400, "y": 400 }
    },
    {
      "name": "PostgreSQL Standby",
      "component_type": "database",
      "host": "db-standby.prod.internal",
      "check_cmd": "pg_isready -h localhost -p 5432 -U appuser",
      "start_cmd": "systemctl start postgresql-16",
      "stop_cmd": "systemctl stop postgresql-16",
      "check_interval_secs": 30,
      "start_timeout_secs": 60,
      "stop_timeout_secs": 120,
      "integrity_check_cmd": "psql -U appuser -c \"SELECT CASE WHEN pg_last_wal_replay_lsn() IS NOT NULL THEN 'replicating' ELSE 'not_replicating' END\"",
      "position": { "x": 600, "y": 400 }
    },
    {
      "name": "Redis Cache",
      "component_type": "cache",
      "host": "cache-01.prod.internal",
      "check_cmd": "redis-cli -h localhost -p 6379 ping",
      "start_cmd": "systemctl start redis",
      "stop_cmd": "systemctl stop redis",
      "check_interval_secs": 15,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 30,
      "position": { "x": 500, "y": 300 }
    },
    {
      "name": "App Server 1",
      "component_type": "application",
      "host": "app-01.prod.internal",
      "check_cmd": "curl -sf http://localhost:8080/actuator/health | grep -q UP",
      "start_cmd": "/opt/ecommerce/bin/start.sh",
      "stop_cmd": "/opt/ecommerce/bin/stop.sh --graceful --timeout 30",
      "check_interval_secs": 30,
      "start_timeout_secs": 120,
      "stop_timeout_secs": 60,
      "integrity_check_cmd": "curl -sf http://localhost:8080/actuator/health/db | grep -q UP",
      "position": { "x": 350, "y": 200 }
    },
    {
      "name": "App Server 2",
      "component_type": "application",
      "host": "app-02.prod.internal",
      "check_cmd": "curl -sf http://localhost:8080/actuator/health | grep -q UP",
      "start_cmd": "/opt/ecommerce/bin/start.sh",
      "stop_cmd": "/opt/ecommerce/bin/stop.sh --graceful --timeout 30",
      "check_interval_secs": 30,
      "start_timeout_secs": 120,
      "stop_timeout_secs": 60,
      "integrity_check_cmd": "curl -sf http://localhost:8080/actuator/health/db | grep -q UP",
      "position": { "x": 550, "y": 200 }
    },
    {
      "name": "Batch Processor",
      "component_type": "batch",
      "host": "batch-01.prod.internal",
      "check_cmd": "pgrep -f 'ecommerce-batch' > /dev/null",
      "start_cmd": "/opt/ecommerce/bin/batch-start.sh",
      "stop_cmd": "/opt/ecommerce/bin/batch-stop.sh --wait-completion",
      "check_interval_secs": 60,
      "start_timeout_secs": 30,
      "stop_timeout_secs": 300,
      "position": { "x": 700, "y": 200 }
    },
    {
      "name": "HAProxy Load Balancer",
      "component_type": "loadbalancer",
      "host": "lb-01.prod.internal",
      "check_cmd": "curl -sf http://localhost:8404/stats | grep -q 'UP'",
      "start_cmd": "systemctl start haproxy",
      "stop_cmd": "systemctl stop haproxy",
      "check_interval_secs": 15,
      "start_timeout_secs": 10,
      "stop_timeout_secs": 10,
      "infra_check_cmd": "ss -tlnp | grep -q ':443'",
      "position": { "x": 450, "y": 50 }
    }
  ],
  "dependencies": [
    { "from": "App Server 1", "to": "PostgreSQL Primary", "type": "strong" },
    { "from": "App Server 1", "to": "Redis Cache", "type": "weak" },
    { "from": "App Server 2", "to": "PostgreSQL Primary", "type": "strong" },
    { "from": "App Server 2", "to": "Redis Cache", "type": "weak" },
    { "from": "Batch Processor", "to": "PostgreSQL Primary", "type": "strong" },
    { "from": "PostgreSQL Standby", "to": "PostgreSQL Primary", "type": "strong" },
    { "from": "HAProxy Load Balancer", "to": "App Server 1", "type": "strong" },
    { "from": "HAProxy Load Balancer", "to": "App Server 2", "type": "strong" }
  ],
  "notes": {
    "start_order": "PostgreSQL Primary → PostgreSQL Standby + Redis Cache (parallel) → App Server 1 + App Server 2 + Batch Processor (parallel) → HAProxy",
    "stop_order": "HAProxy → App Servers + Batch (parallel) → Redis + Standby (parallel) → PostgreSQL Primary",
    "dr_site": "Standby can be promoted via switchover. App servers have site_overrides for DR config."
  }
}
