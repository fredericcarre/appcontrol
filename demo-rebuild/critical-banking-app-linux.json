{
  "name": "Critical Banking App Demo",
  "description": "Linux flavor of the critical banking app demo: web portal + JBoss fan-out tier + Oracle RAC + MQ. Primary site + DR switchover. Rebuild commands are wired to mock XL Deploy / XL Release CLIs. All state lives under /tmp/appcontrol-demo-rebuild/<site>/*.running so the demo runs without real middleware.",
  "tags": {
    "env": "demo",
    "scenario": "fan-out-rebuild-dr",
    "os": "linux"
  },
  "components": [
    {
      "name": "Oracle RAC",
      "display_name": "Oracle RAC (core database)",
      "component_type": "database",
      "host": "agent-primary",
      "cluster_size": 2,
      "cluster_nodes": ["oracle-rac-01.primary.local", "oracle-rac-02.primary.local"],
      "rebuild_protected": true,
      "check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/oracle-rac.running",
      "start_cmd": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/oracle-rac.running",
      "stop_cmd": "rm -f /tmp/appcontrol-demo-rebuild/primary/oracle-rac.running",
      "rebuild_cmd": "/tmp/appcontrol-demo-rebuild/bin/xlr-cli.sh trigger --template 'Oracle RAC Rebuild PROD' --var target=oracle-rac-01.primary.local --wait-complete",
      "integrity_check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/oracle-rac.running",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 90,
      "stop_timeout_seconds": 60,
      "position": { "x": 100, "y": 500 },
      "site_overrides": [
        {
          "site_code": "DR",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/dr/oracle-rac.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/dr && touch /tmp/appcontrol-demo-rebuild/dr/oracle-rac.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/dr/oracle-rac.running",
          "rebuild_cmd_override": "/tmp/appcontrol-demo-rebuild/bin/xlr-cli.sh trigger --template 'Oracle RAC Rebuild DR' --var target=oracle-rac-01.dr.local --wait-complete"
        }
      ]
    },
    {
      "name": "MQ Series",
      "display_name": "MQ Series (transactional bus)",
      "component_type": "middleware",
      "host": "agent-primary",
      "check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/mq-series.running",
      "start_cmd": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/mq-series.running",
      "stop_cmd": "rm -f /tmp/appcontrol-demo-rebuild/primary/mq-series.running",
      "rebuild_cmd": "/tmp/appcontrol-demo-rebuild/bin/xldeploy-cli.sh deploy --package mq-series:9.2.4 --target mq-prd-01.primary.local --wait",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 60,
      "stop_timeout_seconds": 30,
      "position": { "x": 400, "y": 500 },
      "site_overrides": [
        {
          "site_code": "DR",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/dr/mq-series.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/dr && touch /tmp/appcontrol-demo-rebuild/dr/mq-series.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/dr/mq-series.running"
        }
      ]
    },
    {
      "name": "JBoss App Pool",
      "display_name": "JBoss App Tier (fan-out, 6 nodes)",
      "component_type": "appserver",
      "host": "agent-primary",
      "cluster_mode": "fan_out",
      "cluster_health_policy": "threshold_pct",
      "cluster_min_healthy_pct": 80,
      "check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-default.running",
      "start_cmd": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-default.running",
      "stop_cmd": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-default.running",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 90,
      "stop_timeout_seconds": 45,
      "position": { "x": 400, "y": 350 },
      "cluster_members": [
        {
          "hostname": "jboss-prd-001.primary.local",
          "install_path": "/opt/jboss/node-001",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-001.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-001.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-001.running"
        },
        {
          "hostname": "jboss-prd-002.primary.local",
          "install_path": "/opt/jboss/node-002",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-002.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-002.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-002.running"
        },
        {
          "hostname": "jboss-prd-003.primary.local",
          "install_path": "/opt/jboss/node-003",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-003.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-003.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-003.running"
        },
        {
          "hostname": "jboss-prd-004.primary.local",
          "install_path": "/opt/jboss/node-004",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-004.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-004.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-004.running"
        },
        {
          "hostname": "jboss-prd-005.primary.local",
          "install_path": "/opt/jboss/node-005",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-005.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-005.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-005.running"
        },
        {
          "hostname": "jboss-prd-006.primary.local",
          "install_path": "/opt/jboss/node-006",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/primary/jboss-006.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/jboss-006.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/primary/jboss-006.running"
        }
      ],
      "site_overrides": [
        {
          "site_code": "DR",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/dr/jboss-default.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/dr && touch /tmp/appcontrol-demo-rebuild/dr/jboss-default.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/dr/jboss-default.running"
        }
      ]
    },
    {
      "name": "WebSphere Portal",
      "display_name": "WebSphere Portal (online banking)",
      "component_type": "webfront",
      "host": "agent-primary",
      "check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/websphere-portal.running",
      "start_cmd": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/websphere-portal.running",
      "stop_cmd": "rm -f /tmp/appcontrol-demo-rebuild/primary/websphere-portal.running",
      "rebuild_cmd": "/tmp/appcontrol-demo-rebuild/bin/xldeploy-cli.sh deploy --package websphere-portal:8.5.5 --target wsp-prd-01.primary.local --wait",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 60,
      "stop_timeout_seconds": 30,
      "position": { "x": 400, "y": 200 },
      "site_overrides": [
        {
          "site_code": "DR",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/dr/websphere-portal.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/dr && touch /tmp/appcontrol-demo-rebuild/dr/websphere-portal.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/dr/websphere-portal.running"
        }
      ]
    },
    {
      "name": "F5 Load Balancer",
      "display_name": "F5 BIG-IP (load balancer, 2 active nodes)",
      "component_type": "loadbalancer",
      "host": "agent-primary",
      "cluster_size": 2,
      "cluster_nodes": ["f5-prd-01.primary.local", "f5-prd-02.primary.local"],
      "check_cmd": "test -f /tmp/appcontrol-demo-rebuild/primary/f5-lb.running",
      "start_cmd": "mkdir -p /tmp/appcontrol-demo-rebuild/primary && touch /tmp/appcontrol-demo-rebuild/primary/f5-lb.running",
      "stop_cmd": "rm -f /tmp/appcontrol-demo-rebuild/primary/f5-lb.running",
      "check_interval_seconds": 10,
      "start_timeout_seconds": 30,
      "stop_timeout_seconds": 15,
      "position": { "x": 400, "y": 50 },
      "site_overrides": [
        {
          "site_code": "DR",
          "check_cmd_override": "test -f /tmp/appcontrol-demo-rebuild/dr/f5-lb.running",
          "start_cmd_override": "mkdir -p /tmp/appcontrol-demo-rebuild/dr && touch /tmp/appcontrol-demo-rebuild/dr/f5-lb.running",
          "stop_cmd_override": "rm -f /tmp/appcontrol-demo-rebuild/dr/f5-lb.running"
        }
      ]
    }
  ],
  "dependencies": [
    { "from": "JBoss App Pool", "to": "Oracle RAC", "type": "strong" },
    { "from": "JBoss App Pool", "to": "MQ Series", "type": "strong" },
    { "from": "WebSphere Portal", "to": "JBoss App Pool", "type": "strong" },
    { "from": "F5 Load Balancer", "to": "WebSphere Portal", "type": "strong" }
  ]
}
