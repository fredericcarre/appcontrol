# AppControl Production Configuration
# Copy this file to .env and customize

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# PostgreSQL password (generate with: openssl rand -base64 24)
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_RANDOM_PASSWORD

# JWT signing secret (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
# Options:
#   demo        - Quick login (no password), pre-filled admin email, ideal for evaluation
#   development - Same as demo, but shows "Development Mode" warning
#   production  - Strict security, requires OIDC/SAML SSO, strong JWT_SECRET required
APP_ENV=demo

# =============================================================================
# SEED CONFIGURATION (first startup only)
# =============================================================================
# Creates initial organization and admin user when database is empty
SEED_ENABLED=true
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_DISPLAY_NAME=Admin
SEED_ORG_NAME=Default Organization
SEED_ORG_SLUG=default

# =============================================================================
# SSO AUTHENTICATION (for APP_ENV=production)
# =============================================================================
# AUTH_MODE options: oidc, saml
# AUTH_MODE=oidc

# =============================================================================
# OIDC CONFIGURATION (if AUTH_MODE=oidc)
# =============================================================================
# OIDC_DISCOVERY_URL=https://login.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=appcontrol
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://appcontrol.example.com/api/v1/auth/oidc/callback

# =============================================================================
# SAML CONFIGURATION (if AUTH_MODE=saml)
# =============================================================================
# SAML_IDP_SSO_URL=https://idp.example.com/sso
# SAML_IDP_CERT=/path/to/idp-cert.pem
# SAML_SP_ENTITY_ID=https://appcontrol.example.com

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# PostgreSQL
POSTGRES_DB=appcontrol
POSTGRES_USER=appcontrol
POSTGRES_PORT=5432

# Ports
BACKEND_PORT=3000
FRONTEND_PORT=8080
GATEWAY_PORT=4443

# CORS (comma-separated origins, e.g., https://appcontrol.example.com)
CORS_ORIGINS=

# JWT issuer name
JWT_ISSUER=appcontrol

# Logging level
RUST_LOG=info

# AppControl version (defaults to latest)
# APPCONTROL_VERSION=0.2.0
