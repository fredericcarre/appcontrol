# Release Dockerfile - uses pre-built binary (no build stage)
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*
RUN groupadd -r appcontrol && useradd -r -g appcontrol -s /sbin/nologin appcontrol

ARG BINARY_PATH=appcontrol-agent-linux-amd64
COPY ${BINARY_PATH} /usr/local/bin/appcontrol-agent
RUN chmod +x /usr/local/bin/appcontrol-agent

USER appcontrol
ENV RUST_LOG=info
CMD ["appcontrol-agent"]
